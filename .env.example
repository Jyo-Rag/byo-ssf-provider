# SSF Provider Environment Variables
# Copy this file to .env.local and fill in your values

# RSA Key ID - unique identifier for your key
SSF_KEY_ID=your-key-id

# RSA Private Key (PEM format, with newlines escaped as \n)
# Generate using: npm run generate-keys
SSF_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# RSA Public Key (PEM format, with newlines escaped as \n)
# Generate using: npm run generate-keys
SSF_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: Override the app URL (useful for development)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
